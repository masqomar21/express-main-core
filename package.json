{
  "name": "starter-express-ts",
  "version": "1.1.0",
  "description": "starter project for express with typescript",
  "main": "index.js",
  "scripts": {
    "db:seed": "ts-node ./src/db/seeder/index.ts",
    "db:seed:reverse": "ts-node ./scripts/generate-seeders.ts",
    "prisma:lint": "ts-node scripts/lint-prisma-schema.ts",
    "prisma:format": "npx prisma format",
    "migrate": "npm run prisma:format && npm run prisma:lint && prisma migrate dev && prisma generate",
    "migrate:generate": "prisma migrate generate",
    "migrate:deploy": "prisma migrate deploy && prisma generate",
    "migrate:reset": "prisma migrate reset --force && prisma generate",
    "migrate:reset:seed": "prisma migrate reset --force && prisma generate && npm run db:seed",
    "start:worker": "node dist/src/workers/index.js",
    "dev:worker": "ts-node src/workers/index.ts",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register app.ts",
    "notif": "node scripts/generate-vapid.js --file ./.env",
    "prebuild": "node scripts/generate-build-time.js",
    "build": "tsc && tsc-alias",
    "start": "node dist/app.js",
    "test": "test",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "lint:prettier": "prettier --write .",
    "prepare": "husky"
  },
  "repository": {},
  "keywords": [],
  "author": "newus-tect",
  "license": "ISC",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@types/bcrypt": "^6.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^25.9.5",
    "@types/nodemailer": "^8.0.1",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/s3-request-presigner": "^3.1086.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.3.0",
    "bullmq": "^5.80.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^3.4.0",
    "express": "^5.2.1",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.4.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.22.0",
    "prisma": "^6.19.3",
    "puppeteer": "^24.43.1",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.1",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  }
}
